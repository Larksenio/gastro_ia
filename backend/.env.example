# ──────────────────────────────────────────────────────────────
# Archivo de ejemplo para las variables de entorno.
# PASOS:
#   1. Copia este archivo y renómbralo como: .env
#   2. Pega tu clave real de Anthropic en ANTHROPIC_API_KEY
#   3. NUNCA subas el archivo .env a GitHub (ya está en .gitignore)
# ──────────────────────────────────────────────────────────────

# Tu clave de API de Anthropic (la consigues en https://console.anthropic.com)
ANTHROPIC_API_KEY=tu_clave_aqui
# Puerto en el que correrá el servidor (puedes dejarlo en 3000)
PORT=3000
